# IAMGODIAM HARNESS — Environment Template
# DAG: phase0-agentstore-harness-2026-0520 + phase0-hallways-harness-2026-0520
# Copy to .env and fill in values

# ── DATABASE (Render PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql://hallways_user:PASSWORD@dpg-d874h7n7f7vs73d77p70-a.ohio-postgres.render.com:5432/hallways

# ── AUTH ───────────────────────────────────────────────────
NEXTAUTH_SECRET=          # generate: npx auth secret
AUTH_URL=http://localhost:3000

# ── APP ────────────────────────────────────────────────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=dev
SERVICE_MODE=web,worker

# ── EMAIL (Resend) ─────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=           # get from resend.com

# ── PAYMENTS (Stripe) ──────────────────────────────────────
STRIPE_SECRET_KEY=        # sk_live_... or sk_test_...
STRIPE_PUBLISHABLE_KEY=   # pk_live_... or pk_test_...
STRIPE_WEBHOOK_SECRET=    # whsec_...

# ── CRYPTO PAYOUTS (NowPayments) ──────────────────────────
NOWPAYMENTS_API_KEY=      # for EDEN/USDT publisher payouts

# ── ANALYTICS (PostHog) ────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── ANTI-ABUSE (Cloudflare Turnstile) ─────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── AI (Cohere Command A+) ─────────────────────────────────
COHERE_API_KEY=           # command-a-plus-05-2026
